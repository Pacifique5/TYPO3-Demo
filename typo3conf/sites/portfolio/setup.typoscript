@import 'EXT:fluid_styled_content/Configuration/TypoScript/setup.typoscript'

page = PAGE
page {
    10 = CONTENT
    10 {
        table = tt_content
        select {
            orderBy = sorting
            where = colPos=0
        }
    }
    
    includeCSS {
        bootstrap = https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css
        bootstrap.external = 1
    }
}
